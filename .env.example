# Copy to .env.local and fill in. Restart `pnpm dev` after changes.

VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
# Contact, Register, Teacher bio
VITE_EMAILJS_TEMPLATE_ID=
